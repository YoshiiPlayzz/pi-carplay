     out_drm_info->vinfo.offset[1] = pix_mp->height * 128;
     out_drm_info->vinfo.stride[0] = pix_mp->plane_fmt[0].bytesperline;
     out_drm_info->vinfo.stride[1] = pix_mp->plane_fmt[0].bytesperline;
