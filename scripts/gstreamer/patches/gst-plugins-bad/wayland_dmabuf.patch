Description: wayland: dmabuf: Translate column mode tile strides
Author: Dave Stevenson <dave.stevenson@raspberrypi.com>
Origin: <upstream|backport|vendor|other>, <URL, required except if Author is present>
Last-Update: 2026-02-27 <YYYY-MM-DD, last update of the meta-information, optional>
---
This patch header follows DEP-3: http://dep.debian.net/deps/dep3/
--- a/gst-libs/gst/wayland/gstwllinuxdmabuf.c
+++ b/gst-libs/gst/wayland/gstwllinuxdmabuf.c
@@ -90,8 +90,18 @@ get_drm_stride (const GstVideoFormatInfo
   if (!GST_VIDEO_FORMAT_INFO_IS_TILED (finfo))
     return stride;
 
-  return GST_VIDEO_TILE_X_TILES (stride) *
-      GST_VIDEO_FORMAT_INFO_TILE_STRIDE (finfo, plane);
+  switch (finfo->tile_mode) {
+    case GST_VIDEO_TILE_MODE_ZFLIPZ_2X2:
+    case GST_VIDEO_TILE_MODE_LINEAR:
+      return GST_VIDEO_TILE_X_TILES (stride) *
+          GST_VIDEO_FORMAT_INFO_TILE_STRIDE (finfo, plane);
+    case GST_VIDEO_TILE_MODE_COLUMN:
+      return GST_VIDEO_TILE_Y_TILES (stride) *
+          GST_VIDEO_FORMAT_INFO_TILE_HEIGHT (finfo, plane);
+    default:
+      g_assert_not_reached ();
+      return 0;
+  }
 }
 
 struct wl_buffer *
