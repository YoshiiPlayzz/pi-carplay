Description: wayland: don't crash on output property updates (e.g. resize)
 output_done() fetched the GstWlDisplay with g_object_steal_data(), assuming it
 runs once per output. A compositor re-sending wl_output geometry/mode/done (a
 nested compositor resizing its output) makes self NULL and g_mutex_lock() on a
 bogus private pointer segfaults. Clone the output instead of stealing, and
 return the correct global id for output removal.
Origin: https://gitlab.freedesktop.org/gstreamer/gstreamer/-/merge_requests/11741
Forwarded: yes
--- a/gst-libs/gst/wayland/gstwldisplay.c
+++ b/gst-libs/gst/wayland/gstwldisplay.c
@@ -404,9 +404,10 @@ output_description (void *data, struct wl_output *wl_output,
 static void
 output_done (void *data, struct wl_output *wl_output)
 {
-  GstWlOutput *output = GST_WL_OUTPUT (data);
-  GstWlDisplay *self = g_object_steal_data (G_OBJECT (output), "display");
+  GstWlOutput *shared_output = GST_WL_OUTPUT (data);
+  GstWlDisplay *self = g_object_get_data (G_OBJECT (shared_output), "display");
   GstWlDisplayPrivate *priv = gst_wl_display_get_instance_private (self);
+  GstWlOutput *output = gst_wl_output_clone (shared_output);
   const gchar *name = gst_wl_output_get_name (output);
 
   GST_INFO ("Adding output %s (%p):", name, wl_output);
@@ -429,6 +430,7 @@ output_done (void *data, struct wl_output *wl_output)
   GST_INFO ("  Transform:  %i", gst_wl_output_get_transform (output));
   GST_INFO ("---");
 
+
   g_mutex_lock (&priv->outputs_mutex);
   if (name)
     g_hash_table_replace (priv->outputs, g_strdup (name), output);
